(let ((pkg-name 'gptel-mcp)
      (pkg-dir (expand-file-name "elpa/gptel-mcp" user-emacs-directory)))
  
  ;; 1. Tell Emacs to uninstall the package metadata
  (when (package-installed-p pkg-name)
    (condition-case nil
        (package-delete (cadr (assq pkg-name package-alist)))
      (error (message "Package-delete had an issue, proceeding to manual cleanup..."))))

  ;; 2. Physically remove the directory (the "nuclear" option)
  (when (file-exists-p pkg-dir)
    (delete-directory pkg-dir t)
    (message "Deleted gptel-mcp directory."))

  ;; 3. Fresh install from the specific VC branch
  (package-vc-install 
   '(gptel-mcp :url "https://github.com/calebpower/gptel-mcp.el" 
               :branch "bugfix/void-variable-error")))
